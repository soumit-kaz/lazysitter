{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://provenforge.dev/schemas/roster.schema.json",
  "title": "Provenforge roster",
  "description": "Authoritative Provenforge roster consumed by the installer to render the Claude Code and Codex adapters.",
  "type": "object",
  "required": ["version", "tiers", "modelTierByLogical", "neverSkip", "agents"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "tiers": {
      "type": "object",
      "description": "Human-readable description of each capability tier.",
      "additionalProperties": { "type": "string" }
    },
    "modelTierByLogical": {
      "type": "object",
      "description": "Maps a logical Claude model name (opus/sonnet/haiku) to a capability tier.",
      "additionalProperties": { "type": "string", "enum": ["high", "high_alt", "mid", "low"] }
    },
    "neverSkip": {
      "type": "array",
      "description": "Agents triage may never remove, regardless of feature size.",
      "items": { "type": "string" }
    },
    "agents": {
      "type": "object",
      "description": "Per-agent runtime configuration keyed by agent name.",
      "additionalProperties": {
        "type": "object",
        "required": ["tier", "codexSandbox", "codexApproval"],
        "additionalProperties": false,
        "properties": {
          "tier": { "type": "string", "enum": ["high", "high_alt", "mid", "low"] },
          "codexSandbox": {
            "type": "string",
            "enum": ["read-only", "workspace-write", "danger-full-access"]
          },
          "codexApproval": {
            "type": "string",
            "enum": ["never", "on-request", "on-failure", "untrusted"]
          },
          "distinctModel": {
            "type": "boolean",
            "description": "When true, run this agent on the high_alt model slot to avoid shared blind spots with the build lineage."
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
